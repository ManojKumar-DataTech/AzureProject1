{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adfsptPr"
		},
		"AzureDataLakeStorage1service_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorage1service'"
		},
		"AzureSqlservice_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlservice'"
		},
		"azuresql_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'azuresql'"
		},
		"datalake_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'datalake'"
		},
		"AzureDataLakeStorage1service_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://azsptstorage.dfs.core.windows.net/"
		},
		"AzureSqlservice_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sqldbserver321.database.windows.net"
		},
		"AzureSqlservice_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sptsqlDb"
		},
		"AzureSqlservice_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "Adminmanoj"
		},
		"azuresql_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "azureporjectserver1.database.windows.net"
		},
		"azuresql_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "azuresqldatabase"
		},
		"azuresql_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adminmanoj"
		},
		"datalake_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://azureaccountstorage.dfs.core.windows.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adfsptPr_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDataLakeStorage1service_accountKey": {
						"value": "[parameters('AzureDataLakeStorage1service_accountKey')]"
					},
					"AzureSqlservice_password": {
						"value": "[parameters('AzureSqlservice_password')]"
					},
					"azuresql_password": {
						"value": "[parameters('azuresql_password')]"
					},
					"datalake_accountKey": {
						"value": "[parameters('datalake_accountKey')]"
					},
					"AzureDataLakeStorage1service_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage1service_properties_typeProperties_url')]"
					},
					"AzureSqlservice_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlservice_properties_typeProperties_server')]"
					},
					"AzureSqlservice_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlservice_properties_typeProperties_database')]"
					},
					"AzureSqlservice_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlservice_properties_typeProperties_userName')]"
					},
					"azuresql_properties_typeProperties_server": {
						"value": "[parameters('azuresql_properties_typeProperties_server')]"
					},
					"azuresql_properties_typeProperties_database": {
						"value": "[parameters('azuresql_properties_typeProperties_database')]"
					},
					"azuresql_properties_typeProperties_userName": {
						"value": "[parameters('azuresql_properties_typeProperties_userName')]"
					},
					"datalake_properties_typeProperties_url": {
						"value": "[parameters('datalake_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}